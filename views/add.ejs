<!DOCTYPE html>
<html>
<head>
  <title>Add Book</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="container">
  <h1>➕ Add a New Book</h1>

  <form action="/add" method="POST">
    <input type="text" name="title" placeholder="Book Title" required />
    <input type="text" name="author" placeholder="Author" required />
    <input type="text" name="cover_url" placeholder="Cover Image URL" />
    <input type="number" name="rating" min="1" max="5" placeholder="Rating (1-5)" />
    <input type="date" name="date_read" placeholder="Date Read" />
    <textarea name="notes" rows="4" placeholder="Your Notes..."></textarea>
    <div style="display:flex; gap:10px; margin-top:10px;">
      <button type="submit">💾 Save</button>
      <a href="/">⬅ Cancel</a>
    </div>
  </form>
</div>

</body>
</html>